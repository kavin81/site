---
import { siteConfig } from "../site.config";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Github, Download } from "lucide-astro";

---

<BaseLayout meta={{ title: siteConfig.title, desc: siteConfig.desc }}>
    <!-- card -->
    <div class="hero">
        <div class="card">
            <h1 class="title">
                Hey,I'm <span class="name_underline">{siteConfig.author}</span>
            </h1>
            <div class="desc">
                <p>
                    A computer science student at <a
                        class="links"
                        href="https://pes.edu/">PESU</a
                    > & a fullstack developer.
                </p>
                <p>
                    Based in <a
                        class="links"
                        href="https://www.google.com/maps/place/Bengaluru,+Karnataka/"
                        >Bangalore,India</a>
                </p>
            </div>
            <div class="cta">
                <a
                    class="button"
                    href=`https://github.com/${siteConfig.connect.github}`
                    >View Github<div><Github /></div></a
                >
                <a class="button" href="/assets/resume.pdf"
                    >Read Resume<div><Download /></div></a
                >
            </div>
        </div>

        <img class="pfp" src="/favicon.png" alt="Astro Logo" />
    </div>
    <!-- empty card -->
    <div class="empty_space"></div>
</BaseLayout>

<style>
    .hero {
        display: flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;

        gap: 15rem;
        padding-right: 5rem;
        width: 100%;

        .title {
            font-size: 50px;
            font-family: "Inter", var(--serif-font);

            .name_underline {
                position: relative;

                &::after {
                    position: absolute;
                    display: block;
                    z-index: -1;

                    content: "";

                    background-size: cover;
                    background-image: url("/underline.svg");
                    background-repeat: no-repeat;
                    background-size: 100% 100%;

                    top: calc(100% - 0.15em);
                    height: 0.3em;
                    width: calc(100% + 0.4em);
                    left: -0.2em;
                }
            }
        }
        .desc {
            margin-bottom: 25px;
        }
        .desc p {
            margin: 0;
            .links {
                color: white;
                font-weight: 500;
                font-family: var(--monospace-font);
                font-size: 16px;
                text-decoration-color: rgb(82, 82, 82);
                text-underline-offset: 2px;
                line-height: 25px;
            }
        }

        .card {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            padding: 1rem;
            margin: 1rem;

            .cta a.button {
                text-decoration: none;
                cursor: default;
                display: inline-flex;
                align-items: center;
                justify-content: space-between;
                color: white;
                text-align: start;

                padding: 0.5rem 0.75rem;

                background-color: rgb(10, 10, 10);
                border-color: rgb(31, 31, 31);
                border-style: solid;
                border-width: 1px;
                font-family: var(--monospace-font);

                svg {
                    padding-left: 35px;
                    height: 1.5em;
                    width: 1.3em;
                }

                &:hover {
                    background-color: rgb(31, 31, 31);
                    border-color: rgb(50, 50, 50);
                    color: rgba(255, 255, 255, 0.8);
                    border-width: 1.5px;

                    svg {
                        color: inherit;
                    }
                }
            }
        }
        .pfp {
            /* border-radius: 50%; */
            /* object-fit: cover; */
            width: 200px;
            height: 200px;
            margin-top: 55px;
        }
    }

    .empty_space {
        height: 50vh;
    }
</style>
